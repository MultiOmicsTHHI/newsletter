# Copy to secrets.env and fill in. secrets.env is git-ignored / never shared.

# Summary provider: claude_cli | anthropic | openai | perplexity | none
LLM_PROVIDER=claude_cli
# Model name (provider-specific). Empty = sensible default.
LLM_MODEL=
# Optional base URL override (used for openai-compatible providers like
# OpenRouter, Together, Groq). Perplexity is hard-coded internally.
LLM_BASE_URL=

# Only needed if LLM_PROVIDER is "anthropic"
ANTHROPIC_API_KEY=

# Only needed if LLM_PROVIDER is "openai" or "perplexity"
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Email SMTP creds (only needed for live send; draft mode skips this)
GMAIL_APP_PASSWORD=
GMAIL_USER=bioinfo.multiomics@technion.ac.il
